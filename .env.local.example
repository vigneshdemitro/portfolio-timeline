# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit your actual .env.local

# URL to your timeline.json in your portfolio-data GitHub repo
# Vite requires VITE_ prefix to expose env vars to the browser
VITE_TIMELINE_DATA_URL=https://raw.githubusercontent.com/vigneshdemitro/portfolio-data/main/timeline.json
